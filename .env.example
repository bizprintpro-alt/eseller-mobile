# ─── Малчнаас шууд (direct-from-herder marketplace, PRD v1.0) ─────────────
# Master kill-switch for the entire herder/coordinator vertical.
# All herder UI, routes, and the role-switcher pill respect this flag.
# Defaults to OFF. Set to "1" or "true" to enable.
EXPO_PUBLIC_MALCHNAAS_ENABLED=1

# Pilot aimag codes (comma-separated, uppercase). Herder onboarding is
# hard-gated to these aimags so we don't accept applications we can't
# fulfill logistically. Defaults to Архангай / Төв / Сэлэнгэ per PRD §8.
# Codes from src/features/herder/constants.ts PROVINCES.
EXPO_PUBLIC_MALCHNAAS_PILOT_AIMAGS=AKH,TOV,SEL
