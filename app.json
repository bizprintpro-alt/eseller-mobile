{
  "expo": {
    "name": "Eseller.mn",
    "slug": "eseller-mn",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "mn.eseller.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Хүргэлтийн байршил тодорхойлоход",
        "NSCameraUsageDescription": "Бараа зураг авахад",
        "NSPhotoLibraryUsageDescription": "Зураг оруулахад",
        "NSFaceIDUsageDescription": "Аюулгүй нэвтрэхэд"
      }
    },
    "android": {
      "package": "mn.eseller.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Хүргэлтийн байршил тодорхойлоход",
          "locationAlwaysAndWhenInUsePermission": "Хүргэлтийн үед байршил шинэчлэхэд",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-task-manager",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#E8242C"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "scheme": "eseller",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "efa56801-4bb4-4230-9cb9-7a9248182226"
      }
    },
    "owner": "munkhbat25"
  }
}
